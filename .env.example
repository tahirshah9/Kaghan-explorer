# Kaghan Explorer Environment Variables

# Gemini API Key (Injected by AI Studio)
GEMINI_API_KEY=

# App URL (Injected by AI Studio)
APP_URL=

# Weather API Key (Optional, for real weather data)
OPENWEATHER_API_KEY=

# Currency API Key (Optional, for real exchange rates)
EXCHANGERATE_API_KEY=

# Email API Key (Optional, for real contact form emails)
RESEND_API_KEY=
